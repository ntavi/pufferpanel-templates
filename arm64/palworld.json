{
    "type": "palworld-arm64",
    "display": "Palworld Dedicated Server ARM64",
    "icon": "palworld",
    "data": {
        "admin_password": {
            "type": "string",
            "value": "changeme",
            "display": "Admin Password",
            "required": true,
            "userEdit": true
        },
        "extra_flags": {
            "type": "string",
            "value": "-useperfthreads -NoAsyncLoadingThread -UseMultithreadForDS",
            "display": "Extra Flags",
            "required": false,
            "userEdit": true
        },
        "max_players": {
            "type": "integer",
            "value": 32,
            "display": "Max Players",
            "required": true,
            "userEdit": true
        },
        "port": {
            "type": "integer",
            "value": 8211,
            "display": "Game Port",
            "required": true,
            "userEdit": true
        },
        "query_port": {
            "type": "integer",
            "value": 27015,
            "display": "Query Port",
            "required": true,
            "userEdit": false
        },
        "rcon_port": {
            "type": "integer",
            "value": 25575,
            "display": "RCON Port",
            "required": true,
            "userEdit": true
        },
        "server_name": {
            "type": "string",
            "value": "A PufferPanel hosted Palworld Server",
            "display": "Server Name",
            "required": true,
            "userEdit": true
        },
        "server_password": {
            "type": "string",
            "value": "",
            "display": "Server Password",
            "required": false,
            "userEdit": true
        }
    },
    "install": [
        {
            "type": "command",
            "commands": [
                "apt-get update",
                "apt-get -y install tar xz-utils curl git unzip"
            ]
        },
        {
            "type": "writefile",
            "target": "install.sh",
            "text": "#!/bin/sh\nset -e\nexport FEX_APP_DATA_LOCATION=\"$(pwd)/.fex-emu\"\nrm -rf steamapps/appmanifest_2394010.acf\nFEXRootFSFetcher -y -x --distro-name=ubuntu --distro-version=22.04\nmkdir -p steamcmd steamapps\ncurl -sSL -o steamcmd.tar.gz https://steamcdn-a.akamaihd.net/client/installer/steamcmd_linux.tar.gz\ntar -xzvf steamcmd.tar.gz -C steamcmd\nrm steamcmd.tar.gz\nFEXInterpreter ./steamcmd/steamcmd.sh +@sSteamCmdForcePlatformType linux +force_install_dir \"$(pwd)\" +login anonymous +app_update 2394010 validate +quit\n"
        },
        {
            "type": "writefile",
            "text": "#!/bin/sh\nexport FEX_APP_DATA_LOCATION=\"$(pwd)/.fex-emu\"\nexport LD_LIBRARY_PATH=\"$(pwd)/linux64:$LD_LIBRARY_PATH\"\n\nmkdir -p $HOME/.steam/sdk64\nif [ -f ./linux64/steamclient.so ]; then\n  cp ./linux64/steamclient.so $HOME/.steam/sdk64/\nfi\nchmod +x ./Pal/Binaries/Linux/PalServer-Linux-Shipping\n\nif ! id -u puffer > /dev/null 2>&1; then\n  useradd -d \"$(pwd)\" -M puffer\nfi\nchown -R puffer:puffer .\n\nsu -s /bin/bash puffer -c \"\nexport FEX_APP_DATA_LOCATION=\\\"$(pwd)/.fex-emu\\\"\nexport LD_LIBRARY_PATH=\\\"$(pwd)/linux64:\\$LD_LIBRARY_PATH\\\"\nCMD=\\\"FEXInterpreter ./Pal/Binaries/Linux/PalServer-Linux-Shipping Pal -publiclobby ${extra_flags} -port=${port} -publicport=${port} -servername='${server_name}' -players=${max_players} -queryPort=${query_port} -adminpassword='${admin_password}' -rcon\\\"\n\nif [ -n \\\"${server_password}\\\" ]; then\n  CMD=\\\"\\$CMD -serverpassword='${server_password}'\\\"\nfi\n\neval \\$CMD\n\"\n",
            "target": "start.sh"
        },
        {
            "type": "command",
            "commands": [
                "sh install.sh && rm -f install.sh"
            ]
        }
    ],
    "uninstall": null,
    "run": {
        "command": "sh start.sh",
        "stopCode": 2,
        "stdin": {
            "type": "stdin"
        },
        "autostart": false,
        "autorecover": false,
        "autorestart": false
    },
    "environment": {
        "type": "docker",
        "image": "quintenqvd/pterodactyl_images:dev_fex",
        "portBindings": [
            "0.0.0.0:${port}:${port}/udp",
            "0.0.0.0:${rcon_port}:${rcon_port}/tcp",
            "0.0.0.0:${rcon_port}:${rcon_port}/udp"
        ]
    },
    "supportedEnvironments": [
        {
            "type": "docker",
            "networkName": "host",
            "bindings": {},
            "image": "quintenqvd/pterodactyl_images:dev_fex",
            "portBindings": [
                "0.0.0.0:${port}:${port}/udp",
                "0.0.0.0:${rcon_port}:${rcon_port}/tcp",
                "0.0.0.0:${rcon_port}:${rcon_port}/udp",
                "0.0.0.0:${query_port}:${query_port}/udp"
            ],
            "containerRoot": ""
        }
    ],
    "requirements": {
        "os": "linux",
        "arch": "arm64",
        "binaries": [
            "curl",
            "tar",
            "unzip",
            "git"
        ]
    },
    "stats": {
        "type": ""
    },
    "query": {
        "type": ""
    },
    "keepAlive": {
        "frequency": "",
        "command": ""
    },
    "name": "palworld-arm64"
}
