{
    "type": "valheim-arm64",
    "display": "Valheim Dedicated Server ARM64",
    "icon": "valheim",
    "data": {
        "modpack": {
            "type": "string",
            "value": "",
            "display": "Modpack URL",
            "desc": "Open https://thunderstore.io, right-click 'manual download' > copy link. Paste it here to use a modpack.",
            "required": false,
            "userEdit": true
        },
        "name": {
            "type": "string",
            "value": "Valheim Server",
            "display": "Server Name",
            "desc": "Choose your server name.",
            "required": true,
            "userEdit": true
        },
        "password": {
            "type": "string",
            "value": "valheim",
            "display": "Password",
            "desc": "Set the server password.",
            "required": true,
            "userEdit": true
        },
        "port": {
            "type": "integer",
            "value": 2456,
            "display": "Port",
            "desc": "The main game port to bind the server to.",
            "required": true,
            "userEdit": false
        },
        "query_port": {
            "type": "integer",
            "value": 2458,
            "display": "Query Port",
            "desc": "Additional query port for server listing.",
            "required": true,
            "userEdit": true
        },
        "world": {
            "type": "string",
            "value": "VHWorld",
            "display": "World Name",
            "desc": "What worldmap name to use.",
            "required": true,
            "userEdit": true
        }
    },
    "install": [
        {
            "type": "command",
            "commands": [
                "apt-get update",
                "apt-get -y install tar xz-utils curl git unzip"
            ]
        },
        {
            "type": "writefile",
            "target": "install.sh",
            "text": "#!/bin/sh\nset -e\nexport FEX_APP_DATA_LOCATION=\"$(pwd)/.fex-emu\"\n\necho \"Downloading x86_64 RootFS for FEX...\"\nFEXRootFSFetcher -y -x --distro-name=ubuntu --distro-version=22.04\n\necho \"Installing SteamCMD...\"\nmkdir -p steamcmd\ncurl -sSL -o steamcmd.tar.gz https://steamcdn-a.akamaihd.net/client/installer/steamcmd_linux.tar.gz\ntar -xzvf steamcmd.tar.gz -C steamcmd\nrm steamcmd.tar.gz\n\necho \"Installing Valheim...\"\nFEXInterpreter ./steamcmd/steamcmd.sh +force_install_dir \"$(pwd)\" +login anonymous +app_update 896660 validate +quit\n\necho \"Install Complete!\"\n"
        },
        {
            "type": "command",
            "commands": [
                "sh install.sh && rm -f install.sh"
            ]
        },
        {
            "if": "modpack != ''",
            "type": "download",
            "files": [
                "${modpack}"
            ]
        },
        {
            "if": "modpack != ''",
            "type": "command",
            "commands": [
                "unzip -o ./denikson-BepInExPack_Valheim*.zip -d ./bepin_temp/",
                "cp -r ./bepin_temp/BepInExPack_Valheim/. ./",
                "rm -r ./bepin_temp",
                "rm ./denikson-BepInExPack_Valheim*.zip"
            ]
        },
        {
            "type": "writefile",
            "text": "#!/bin/sh\nexport FEX_APP_DATA_LOCATION=\"$(pwd)/.fex-emu\"\nexport LD_LIBRARY_PATH=\"$(pwd)/linux64:$LD_LIBRARY_PATH\"\n\nchmod +x valheim_server.x86_64\nexec FEXInterpreter ./valheim_server.x86_64 -name \"${name}\" -port ${port} -world \"${world}\" -password \"${password}\" -public 1\n",
            "target": "start.sh"
        }
    ],
    "uninstall": null,
    "run": {
        "command": "sh start.sh",
        "stopCode": 2,
        "stdin": {
            "type": "stdin"
        },
        "autostart": false,
        "autorecover": false,
        "autorestart": false
    },
    "environment": {
        "type": "docker",
        "image": "quintenqvd/pterodactyl_images:dev_fex_fivem",
        "portBindings": [
            "0.0.0.0:${port}:${port}/udp",
            "0.0.0.0:${query_port}:${query_port}/udp"
        ]
    },
    "supportedEnvironments": [
        {
            "type": "docker",
            "image": "quintenqvd/pterodactyl_images:dev_fex_fivem",
            "portBindings": [
                "0.0.0.0:${port}:${port}/udp",
                "0.0.0.0:${query_port}:${query_port}/udp"
            ]
        }
    ],
    "requirements": {
        "os": "linux",
        "arch": "arm64",
        "binaries": [
            "curl",
            "tar",
            "unzip",
            "git"
        ]
    },
    "stats": {
        "type": ""
    },
    "query": {
        "type": ""
    },
    "keepAlive": {
        "frequency": "",
        "command": ""
    },
    "name": "valheim-arm64"
}
